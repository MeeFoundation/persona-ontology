@prefix : <http://www.example.org/mee#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix po: <https://purl.org/cco/person/> .
@prefix postal: <https://purl.org/cco/postal-address/> .
@prefix staging: <https://purl.org/cco/staging/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://www.example.org/mee> .

<http://www.example.org/mee> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    rdfs:label "Alice Walker - Example Instance Data"@en ;
    rdfs:comment """Example instance data for a hypothetical user, Alice Walker, of the Mee Identity Agent 
                    demonstrating the Mee Foundation Persona Ontology in practice.
                    
                    Person Details:
                    - Legal Name: Margery Alice Walker  
                    - Goes By: Alice Walker
                    - SSN: 123-45-6788
                    - Email: awalker@gmail.com
                    - Phone: +15108149999
                    - Address: 123 Sleepy Hollow, Paradise, CA 95969, USA
                    - Eye Color: Blue
                    - Height: 68 inches
                    
                    DEMONSTRATES:
                    - Peer name architecture (GivenName, AdditionalName, FamilyName as peers)
                    - New properties (ont00001879 designated by, ont00001765 has text value)
                    - Slash URIs for all domain classes
                    - EyeColor extension usage
                    - Structured postal address with BFO_0000178 (has continuant part)"""@en .


#################################################################
#    Alice Walker - Person Instance
#################################################################

###  Person: Alice Walker
:Alice_Walker rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Alice Walker"@en ;
    rdfs:comment "Person instance demonstrating NEW architecture with peer names."@en ;
    
    # PEER NAMES (No hierarchical PersonName)
    # Legal name: Margery Alice Walker
    # Goes by: Alice Walker
    
    <https://purl.org/cco/ont00001879> [  # designated by → GivenName (legal first name)
        rdf:type po:GivenName ;
        <https://purl.org/cco/ont00001765> "Margery"  # has text value
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → AdditionalName (middle name, but also goes by "Elizabeth")
        rdf:type po:AdditionalName ;
        <https://purl.org/cco/ont00001765> "Elizabeth"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type po:FamilyName ;
        <https://purl.org/cco/ont00001765> "Walker"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → AlternateName (preferred name)
        rdf:type po:AlternateName ;
        <https://purl.org/cco/ont00001765> "Alice Walker" ;
        rdfs:comment "Name she goes by professionally and socially"@en
    ] ;
    
    # IDENTIFIERS
    
    <https://purl.org/cco/ont00001879> [  # designated by → SSN
        rdf:type po:SocialSecurityNumber ;
        <https://purl.org/cco/ont00001765> "123-45-6788"
    ] ;
    
    # CONTACT INFORMATION
    
    <https://purl.org/cco/ont00001879> [  # designated by → Email
        rdf:type staging:EmailAddress ;
        <https://purl.org/cco/ont00001765> "awalker@gmail.com"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → Phone
        rdf:type staging:TelephoneNumber ;
        <https://purl.org/cco/ont00001765> "+15108149999" ;
        rdfs:comment "E.164 format (international standard)"@en
    ] ;
    
    # POSTAL ADDRESS
    
    <https://purl.org/cco/ont00001879> :Home_Address_Paradise ;  # designated by → Address
    
    # PHYSICAL CHARACTERISTICS
    
    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Height
        rdf:type <https://purl.org/cco/ont00000367> ;  # Height (CCO Quality)
        rdfs:comment "Height measurement: 68 inches (5'8\")"@en ;
        <https://purl.org/cco/ont00001689> [  # has measurement
            rdf:type <https://purl.org/cco/ont00001243> ;  # Measurement Information Content Entity
            <https://purl.org/cco/ont00001765> "68"^^xsd:decimal ;
            <https://purl.org/cco/ont00001729> <http://purl.obolibrary.org/obo/UO_0000010>  # unit: inch
        ]
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Eye Color
        rdf:type persona:BlueEyeColor ;
        rdfs:comment "Eye color: Blue (using Mee extension class)"@en
    ] .


#################################################################
#    US Postal Address Instance
#################################################################

###  Home Address: 123 Sleepy Hollow, Paradise, CA 95969, USA
:Home_Address_Paradise rdf:type owl:NamedIndividual ,
                               postal:USPostalAddress ;
    rdfs:label "Home Address - Paradise, CA"@en ;
    rdfs:comment "Primary residential address using NEW architecture with has continuant part."@en ;
    
    # ADDRESS COMPONENTS (using BFO_0000178 has continuant part)
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Street
        rdf:type postal:StreetAddress ;
        <https://purl.org/cco/ont00001765> "123 Sleepy Hollow"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → City
        rdf:type postal:CityName ;
        <https://purl.org/cco/ont00001765> "Paradise"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → State
        rdf:type postal:StateName ;
        <https://purl.org/cco/ont00001765> "CA" ;
        rdfs:comment "USPS 2-letter state code"@en
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → ZIP
        rdf:type postal:PostalCode ;
        <https://purl.org/cco/ont00001765> "95969" ;
        rdfs:comment "5-digit ZIP code"@en
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Country
        rdf:type postal:CountryName ;
        <https://purl.org/cco/ont00001765> "USA" ;
        rdfs:comment "Country name (optional for US addresses)"@en
    ] .


#################################################################
#    ARCHITECTURE COMPARISON NOTES
#################################################################

# OLD Architecture (IEEE Person Ontology):
# ----------------------------------------
# Used hierarchical PersonName with has_part:
#
# :PersonName_MargeryWalker rdf:type po:PersonName ;
#     cco:has_part :GivenName_Margery ;
#     cco:has_part :MiddleName_Alice ;
#     cco:has_part :FamilyName_Walker .
#
# :Alice_Walker cco:has_designator :PersonName_MargeryWalker .
#
# Problems:
# - Implies FullName = concatenation of parts
# - Rigid structure
# - Hash URIs (no content negotiation)
# - Conflicts with international standards


# NEW Architecture (PersonOntology 2.0):
# ---------------------------------------
# Uses peer names with designated by:
#
# :Alice_Walker ont00001879 [ rdf:type po:GivenName ; ont00001765 "Margery" ] ;
#               ont00001879 [ rdf:type po:FamilyName ; ont00001765 "Walker" ] .
#
# Benefits:
# - Flexible (can use FullName OR components OR both)
# - FullName is "how person writes their name" (not automatic concat)
# - Slash URIs (content negotiation enabled)
# - Aligns with Schema.org, FHIR, OpenID, IANA
# - Handles international naming patterns


# PROPERTY CHANGES:
# -----------------
# OLD: cco:has_designator → NEW: ont00001879 (designated by)
# OLD: cco:has_part → NEW: BFO_0000178 (has continuant part) 
# OLD: cco:has_string_value → NEW: ont00001765 (has text value)
# OLD: (not specified) → NEW: BFO_0000196 (bearer of) for qualities


# EXTENSION EXAMPLE:
# ------------------
# EyeColor is a Mee-specific extension in persona.ttl
# May be promoted to PersonOntology if proven useful
# This demonstrates bottom-up innovation model
