@prefix : <http://www.example.org/mee#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mee> .

<http://www.example.org/mee> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    dc:date "2026-04-12"^^xsd:date ;
    owl:versionInfo "Version 3.0.7 - rename Friend to Friends, Colleague to Colleagues"@en ;
    rdfs:label "Alice Walker - Example Instance Data"@en ;
    rdfs:comment """Example instance data for Alice Walker demonstrating the Mee Foundation 
                    Persona Ontology in practice.
                    
                    Person Details:
                    - Legal Name: Margery Alice Walker  
                    - Goes By: Alice Walker
                    - Maiden Name: Margery Alice Arnold
                    - SSN: 123-45-6788
                    - Email: awalker@gmail.com
                    - Phone: +15108149999
                    - Current Address: 123 Sleepy Hollow, Paradise, CA 95969, USA (since Sept 2025)
                    - Height: 68 inches
                    - Eye Color: Blue
                    - Hair Color: Grey
                    - Son: Paul Walker

                    DEMONSTRATES:
                    - Peer name architecture (GivenName, AdditionalName, FamilyName as peers)
                    - Maiden name represented as AlternateName (covers former legal names per CCO scope note)
                    - Parent/child relationships using CCO AgentOntology properties (is parent of / is child of)
                    - Social network partitioned into Family, Friends, Colleagues, Other sub-groups (BFO has part) with possible intersection
                    - New properties (ont00001879 designated by, ont00001765 has text value)
                    - Slash URIs for all domain classes
                    - Structured postal address with BFO_0000178 (has continuant part)
                    - Address history tracking with temporal intervals
                    - Open-ended intervals for current address"""@en .


#################################################################
#    Alice Walker - Person Instance
#################################################################

###  Person: Alice Walker
:Alice_Walker rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Alice Walker"@en ;
    rdfs:comment "Person instance demonstrating peer name architecture and address history."@en ;
    
    # PEER NAMES (No hierarchical PersonName)
    # Legal name: Margery Alice Walker
    # Goes by: Alice Walker
    
    <https://purl.org/cco/ont00001879> [  # designated by → GivenName (legal first name)
        rdf:type cco:ent00000002 ;
        <https://purl.org/cco/ont00001765> "Margery"  # has text value
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → AdditionalName (middle name)
        rdf:type cco:ent00000003 ;
        <https://purl.org/cco/ont00001765> "Alice"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type cco:ent00000004 ;
        <https://purl.org/cco/ont00001765> "Walker"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → AlternateName (goes by)
        rdf:type cco:ent00000006 ;
        <https://purl.org/cco/ont00001765> "Alice Walker" ;
        rdfs:comment "Name she goes by professionally and socially"@en
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → AlternateName (maiden name)
        rdf:type cco:ent00000006 ;
        <https://purl.org/cco/ont00001765> "Margery Alice Arnold" ;
        rdfs:comment "Maiden name (former legal name before marriage)"@en
    ] ;
    
    # IDENTIFIERS
    
    <https://purl.org/cco/ont00001879> [  # designated by → SSN
        rdf:type cco:ent00000008 ;
        <https://purl.org/cco/ont00001765> "123-45-6788"
    ] ;
    
    # CONTACT INFORMATION
    
    <https://purl.org/cco/ont00001879> [  # designated by → Email
        rdf:type cco:ent00000024 ;
        <https://purl.org/cco/ont00001765> "awalker@gmail.com"
    ] ;
    
    <https://purl.org/cco/ont00001879> [  # designated by → Phone
        rdf:type cco:ent00000023 ;
        <https://purl.org/cco/ont00001765> "+15108149999" ;
        rdfs:comment "E.164 format (international standard)"@en
    ] ;
    
    # CURRENT POSTAL ADDRESS
    
    <https://purl.org/cco/ont00001879> :Address_Paradise ;
    
    # PHYSICAL CHARACTERISTICS
    
    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Height
        rdf:type <https://purl.org/cco/ont00000367> ;  # Height (CCO Quality)
        rdfs:comment "Height measurement: 68 inches (5'8\")"@en ;
        <https://purl.org/cco/ont00001689> [  # has measurement
            rdf:type <https://purl.org/cco/ont00001243> ;  # Measurement
            <https://purl.org/cco/ont00001765> "68"^^xsd:decimal ;
            <https://purl.org/cco/ont00001729> <http://purl.obolibrary.org/obo/UO_0000010>  # inch
        ]
    ] ;

    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Eye Color
        rdf:type cco:ent00000040 ;  # Blue Eye Color
        rdfs:comment "Eye color: Blue"@en
    ] ;

    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Scalp Hair
        rdf:type cco:ont00000058 ;  # Scalp Hair
        <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Hair Color
            rdf:type cco:ont00000026 ;  # Hair Color
            <https://purl.org/cco/ont00001765> "Grey" ;  # has text value
            rdfs:comment "Hair color: Grey"@en
        ]
    ] ;

    # FAMILY RELATIONSHIPS

    cco:ont00001786 :Paul_Walker ;  # is mother of

    # SOCIAL NETWORK

    persona:hasSocialNetwork :Alice_Social_Network .


#################################################################
#    Address History - Temporal Tracking
#################################################################

###  Previous Address: Boston (2020-2025)
:Boston_Residence rdf:type owl:NamedIndividual ,
                           cco:ent00000016 ;
    rdfs:label "Alice's Boston Residence (2020-2025)"@en ;
    rdfs:comment "Alice lived at this Boston address from 2020 to 2025."@en ;
    <http://purl.obolibrary.org/obo/BFO_0000139> :Alice_Walker ;  # has participant
    <https://purl.org/cco/ont00001879> :Address_Boston ;  # designated by
    <http://purl.obolibrary.org/obo/BFO_0000153> :Interval_2020_2025 .  # occupies temporal region

:Interval_2020_2025 rdf:type owl:NamedIndividual ,
                             <http://purl.obolibrary.org/obo/BFO_0000038> ;  # TemporalInterval
    rdfs:label "2020-2025"@en ;
    cco:ent00000017 "2020-01-01"^^xsd:date ;
    cco:ent00000018 "2025-08-31"^^xsd:date .

:Address_Boston rdf:type owl:NamedIndividual ,
                         cco:ent00000010 ;
    rdfs:label "Boston Address"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Street
        rdf:type cco:ent00000011 ;
        <https://purl.org/cco/ont00001765> "456 Commonwealth Ave"
    ] ;
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → City
        rdf:type cco:ent00000012 ;
        <https://purl.org/cco/ont00001765> "Boston"
    ] ;
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → State
        rdf:type cco:ent00000013 ;
        <https://purl.org/cco/ont00001765> "MA"
    ] ;
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → ZIP
        rdf:type cco:ent00000015 ;
        <https://purl.org/cco/ont00001765> "02215"
    ] .


###  Current Address: Paradise (2025-present)
:Paradise_Residence rdf:type owl:NamedIndividual ,
                            cco:ent00000016 ;
    rdfs:label "Alice's Paradise Residence (2025-present)"@en ;
    rdfs:comment "Alice has lived at this Paradise address since September 2025. No end date indicates current residence."@en ;
    <http://purl.obolibrary.org/obo/BFO_0000139> :Alice_Walker ;  # has participant
    <https://purl.org/cco/ont00001879> :Address_Paradise ;  # designated by
    <http://purl.obolibrary.org/obo/BFO_0000153> :Interval_2025_Present .  # occupies temporal region

:Interval_2025_Present rdf:type owl:NamedIndividual ,
                                <http://purl.obolibrary.org/obo/BFO_0000038> ;  # TemporalInterval
    rdfs:label "September 2025 to present"@en ;
    rdfs:comment "Open-ended interval - absence of end date indicates current/ongoing"@en ;
    cco:ent00000017 "2025-09-01"^^xsd:date .
    # No cco:ent00000018 = still current


###  Paradise Address Details
:Address_Paradise rdf:type owl:NamedIndividual ,
                          cco:ent00000010 ;
    rdfs:label "Paradise Address"@en ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Street
        rdf:type cco:ent00000011 ;
        <https://purl.org/cco/ont00001765> "123 Sleepy Hollow"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → City
        rdf:type cco:ent00000012 ;
        <https://purl.org/cco/ont00001765> "Paradise"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → State
        rdf:type cco:ent00000013 ;
        <https://purl.org/cco/ont00001765> "CA"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → ZIP
        rdf:type cco:ent00000015 ;
        <https://purl.org/cco/ont00001765> "95969"
    ] ;
    
    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Country
        rdf:type cco:ent00000014 ;
        <https://purl.org/cco/ont00001765> "USA"
    ] .


#################################################################
#    Paul Walker - Person Instance (Alice's son)
#################################################################

:Paul_Walker rdf:type owl:NamedIndividual ,
                      <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Paul Walker"@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → GivenName
        rdf:type cco:ent00000002 ;
        <https://purl.org/cco/ont00001765> "Paul"
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type cco:ent00000004 ;
        <https://purl.org/cco/ont00001765> "Walker"
    ] ;

    # FAMILY RELATIONSHIPS

    cco:ont00001780 :Alice_Walker .  # has mother


#################################################################
#    Alice's Social Network
#################################################################

:Alice_Social_Network rdf:type owl:NamedIndividual ,
                               cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's social network"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000051> :Alice_Family_Network ;     # has part → Family sub-group
    <http://purl.obolibrary.org/obo/BFO_0000051> :Alice_Friends_Network ;     # has part → Friends sub-group
    <http://purl.obolibrary.org/obo/BFO_0000051> :Alice_Colleagues_Network ;  # has part → Colleagues sub-group
    <http://purl.obolibrary.org/obo/BFO_0000051> :Alice_Other_Network .      # has part → Other sub-group

:Alice_Family_Network rdf:type owl:NamedIndividual ,
                               cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's family connections"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Paul_Walker .  # has member part

:Alice_Friends_Network rdf:type owl:NamedIndividual ,
                              cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's friends connections"@en .

:Alice_Colleagues_Network rdf:type owl:NamedIndividual ,
                                  cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's colleagues connections"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Paul_Walker .  # has member part (intersects with Family)

:Alice_Other_Network rdf:type owl:NamedIndividual ,
                              cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's other connections"@en .


#################################################################
#    PATTERN NOTES
#################################################################

# ADDRESS HISTORY PATTERN:
# ------------------------
# Track N addresses over a person's lifetime with temporal bounds.
#
# Each address designation has:
# - Person (BFO has participant)
# - Address (CCO designated by)
# - Time interval (BFO occupies temporal region)
#   - Start date (required)
#   - End date (optional - absence = current address)
#
# Example queries:
# - "Where did Alice live in 2023?" → Boston address
# - "Where does Alice currently live?" → Paradise (no end date)
# - "When did Alice live in Boston?" → 2020-01-01 to 2025-08-31
# - "List all of Alice's addresses" → Boston, Paradise
#
# Extensible for future needs:
# - Multiple simultaneous addresses (add type/role property)
# - Move events (add Act of Change of Residence instances)
# - Address roles (mailing, billing, legal - add properties)
