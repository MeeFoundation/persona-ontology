@prefix : <http://www.example.org/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix cco: <https://purl.org/cco/> .
@prefix mia: <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .

# Imports Mee Identity Agent (MIA)'s Application Ontology (which imports the domains)
<http://www.example.org/shapes> rdf:type owl:Ontology ;
    owl:imports <http://www.example.org/mia> ;
    owl:versionInfo "Version 3.0.3 - extend SocialNetworkShape for has-part sub-groups (Family, Colleague, Other)"@en ;
    rdfs:label "Mee Identity Agent (MIA)'s SHACL Validation Shapes"@en ;
    rdfs:comment """SHACL validation shapes for the Mee Identty Agent.
                    
                    This file demonstrates validation against:
                    - Person Ontology terms
                    - Postal Address Ontology terms  
                    - Staging Ontology terms
                    - CCO core terms (via full IRIs)
                    
                    IMPORTANT ARCHITECTURE CHANGE:
                    The previous version of this file used hierarchical PersonName with has_part.
                    New architecture uses PEER NAMES with direct designated_by relationship.
                    All name types connect directly to Person, no intermediate PersonName.
                    
                    PROPERTY IRIS USED (CCO):
                    - ont00001879 = designated by (Person ← Name/Address)
                    - ont00001765 = has text value (Identifier → literal string)
                    - BFO_0000178 = has continuant part (Address → components)

                    NOTE ON "REQUIRED" TERMS:
                    This ontology marks some classes as "required" for the identity agent schema.
                    In this SHACL file, those terms are NOT required on every Person instance.
                    Instead, SHACL (a) enforces core name requirements for Person, and (b) validates SSN/email/phone/address
                    nodes when they are present and typed with the corresponding class.
"""@en .
#################################################################
#  IRI constants used (full IRIs to avoid prefix drift)
#################################################################

# CCO: designated by (Person <- Identifier/Name/etc.)
#   https://purl.org/cco/ont00001879
# CCO: has text value (Identifier -> literal string)
#   https://purl.org/cco/ont00001765
# BFO: has continuant part (Address -> components)
#   http://purl.obolibrary.org/obo/BFO_0000178

#################################################################
#  Person validation
#  - Enforce Person naming rules.
#  - Do NOT require SSN/email/phone/address per Person.
#  - If those nodes exist and are typed, they are validated by their own NodeShapes.
#################################################################

:PersonShape
    a sh:NodeShape ;
    sh:targetClass <https://purl.org/cco/ont00001262> ;  # Person
    sh:message "Person must have either FullName OR (GivenName + FamilyName). Other designators are validated when present and typed."@en ;

    # Name Requirement: EITHER FullName OR (GivenName AND FamilyName)
    # Using qualified constraints avoids accidentally forcing *all* designated_by values to be name values.
    sh:or (
        [
            sh:property [
                sh:path <https://purl.org/cco/ont00001879> ;  # designated by
                sh:qualifiedValueShape [ sh:class cco:ent00000001 ] ;
                sh:qualifiedMinCount 1 ;
                sh:message "Person must be designated by at least one FullName, OR provide GivenName + FamilyName."@en
            ]
        ]
        [
            sh:and (
                [
                    sh:property [
                        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
                        sh:qualifiedValueShape [ sh:class cco:ent00000002 ] ;
                        sh:qualifiedMinCount 1 ;
                        sh:message "If no FullName is provided, Person must be designated by at least one GivenName."@en
                    ]
                ]
                [
                    sh:property [
                        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
                        sh:qualifiedValueShape [ sh:class cco:ent00000004 ] ;
                        sh:qualifiedMinCount 1 ;
                        sh:message "If no FullName is provided, Person must be designated by at least one FamilyName."@en
                    ]
                ]
            )
        ]
    ) ;

    # Optional name components (not required; validated by type only)
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
        sh:qualifiedValueShape [
            sh:or (
                [ sh:class cco:ent00000003 ]
                [ sh:class cco:ent00000005 ]
                [ sh:class cco:ent00000006 ]
                [ sh:class <https://purl.org/cco/ont00000990> ]  # Nickname
                [ sh:class <https://purl.org/cco/ont00001331> ]  # Legal Name
            )
        ] ;
        sh:qualifiedMaxCount 50 ;
        sh:message "Optional name designators are allowed (up to 50 total across these types)."@en
    ] ;

    # Optional: SSN is allowed (0..1). Validity is enforced by :SSNShape on SSN nodes.
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
        sh:qualifiedValueShape [ sh:class cco:ent00000008 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "At most one SocialSecurityNumber may be attached to a Person."@en
    ] ;

    # Optional: email addresses (0..many). Validity is enforced by :EmailAddressShape on EmailAddress nodes.
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
        sh:qualifiedValueShape [ sh:class cco:ent00000024 ] ;
        sh:qualifiedMaxCount 20 ;
        sh:message "EmailAddress values are optional; if present and typed, they must validate."@en
    ] ;

    # Optional: telephone numbers (0..many). Validity is enforced by :TelephoneNumberShape on TelephoneNumber nodes.
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
        sh:qualifiedValueShape [ sh:class cco:ent00000023 ] ;
        sh:qualifiedMaxCount 20 ;
        sh:message "TelephoneNumber values are optional; if present and typed, they must validate."@en
    ] ;

    # Optional: US postal address (0..1). Validity is enforced by :USPostalAddressShape on address nodes.
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;  # designated by
        sh:qualifiedValueShape [ sh:class cco:ent00000010 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "USPostalAddress is optional; if present and typed, it must validate."@en
    ] ;

    # Optional: scalp hair (0..1), which in turn bears the hair color.
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ont00000058 ] ;  # Scalp Hair
        sh:qualifiedMaxCount 1 ;
        sh:message "At most one ScalpHair continuant part may be asserted on a Person."@en
    ] ;

    # Optional: mother relationship (0..many). Range must be a Person.
    sh:property [
        sh:path cco:ont00001786 ;  # is mother of
        sh:class <https://purl.org/cco/ont00001262> ;  # Person
        sh:message "The object of 'is mother of' must be a Person."@en
    ] ;

    # Optional: has mother (0..1). Range must be a Person.
    sh:property [
        sh:path cco:ont00001780 ;  # has mother
        sh:class <https://purl.org/cco/ont00001262> ;  # Person
        sh:maxCount 1 ;
        sh:message "The object of 'has mother' must be a Person."@en
    ] ;

    # Optional: social network (0..1). Range must be a Social Network.
    sh:property [
        sh:path persona:hasSocialNetwork ;
        sh:class cco:ont00001183 ;  # Social Network
        sh:maxCount 1 ;
        sh:message "A Person may have at most one Social Network; it must be of type Social Network."@en
    ] .

#################################################################
#  SSN validation
#################################################################

:SSNShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000008 ;
    sh:message "Social Security Number must follow NNN-NN-NNNN format."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d{3}-\\d{2}-\\d{4}$" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "SSN must be exactly 9 digits in NNN-NN-NNNN format (e.g., 123-45-6789)."@en
    ] .

#################################################################
#  Email validation
#################################################################

:EmailAddressShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000024 ;
    sh:message "Email must be a single string like local-part@domain (basic validation)."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Must be valid email format: local-part@domain"@en
    ] .

#################################################################
#  Telephone validation
#################################################################

:TelephoneNumberShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000023 ;
    sh:message "Telephone number should follow E.164 format (recommended)."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^\\+?[1-9]\\d{1,14}$" ;  # E.164: +[country][number]
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Recommended format: +15551234567 (E.164)."@en
    ] .

#################################################################
#  US Postal Address validation (qualified parts)
#################################################################

:USPostalAddressShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000010 ;
    sh:message "US Postal Address must have required components (street, city, state, ZIP). Country is optional."@en ;

    # Exactly one StreetAddress part
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ent00000011 ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "Must have exactly one StreetAddress part."@en
    ] ;

    # Exactly one CityName part
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ent00000012 ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "Must have exactly one CityName part."@en
    ] ;

    # Exactly one StateName part
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ent00000013 ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "Must have exactly one StateName part."@en
    ] ;

    # Exactly one PostalCode part
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ent00000015 ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "Must have exactly one PostalCode part."@en
    ] ;

    # Optional CountryName part (0..1)
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000178> ;  # has continuant part
        sh:qualifiedValueShape [ sh:class cco:ent00000014 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "May have at most one CountryName part."@en
    ] .

#################################################################
#  Component validations (if present and typed)
#  These are optional but help catch bad literals when the parts are modeled as identifiers.
#################################################################

:USStateNameShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000013 ;
    sh:message "State must be a valid US/USPS 2-letter abbreviation."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:in ("AL" "AK" "AZ" "AR" "CA" "CO" "CT" "DE" "FL" "GA"
               "HI" "ID" "IL" "IN" "IA" "KS" "KY" "LA" "ME" "MD"
               "MA" "MI" "MN" "MS" "MO" "MT" "NE" "NV" "NH" "NJ"
               "NM" "NY" "NC" "ND" "OH" "OK" "OR" "PA" "RI" "SC"
               "SD" "TN" "TX" "UT" "VT" "VA" "WA" "WV" "WI" "WY"
               "DC" "AS" "GU" "MP" "PR" "VI" "AA" "AE" "AP") ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Must use a valid USPS 2-letter state/territory abbreviation."@en
    ] .

:ZIPCodeShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000015 ;
    sh:message "ZIP Code must be 5-digit or ZIP+4 format."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d{5}(-\\d{4})?$" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Must be 5-digit ZIP (NNNNN) or ZIP+4 (NNNNN-NNNN) format."@en
    ] .

:USACountryNameShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000014 ;
    sh:message "If country is present, it must indicate the United States (controlled list)."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:in ("USA" "US" "UNITED STATES" "UNITED STATES OF AMERICA") ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "If specified, must be USA/US/UNITED STATES (controlled list)."@en
    ] .

#################################################################
#  Scalp Hair / Hair Color validation
#  Hair Color inheres in a portion of Scalp Hair, not directly in the Person.
#  Pattern: Person -[has continuant part]-> ScalpHair -[bearer of]-> HairColor
#################################################################

:ScalpHairShape
    a sh:NodeShape ;
    sh:targetClass cco:ont00000058 ;  # Scalp Hair
    sh:message "ScalpHair must bear exactly one HairColor with a non-empty text value."@en ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000196> ;  # bearer of
        sh:qualifiedValueShape [ sh:class cco:ont00000026 ] ;  # Hair Color
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "ScalpHair must bear exactly one HairColor."@en
    ] .

:HairColorShape
    a sh:NodeShape ;
    sh:targetClass cco:ont00000026 ;  # Hair Color
    sh:message "HairColor must have exactly one text value (a non-empty string)."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "HairColor must have exactly one non-empty string text value."@en
    ] .

#################################################################
#  AlternateName validation (maiden name, preferred name, etc.)
#################################################################

:AlternateNameShape
    a sh:NodeShape ;
    sh:targetClass cco:ent00000006 ;  # AlternateName
    sh:message "AlternateName must have exactly one text value (a non-empty string)."@en ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001765> ;  # has text value
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "AlternateName must have exactly one non-empty string text value."@en
    ] .

#################################################################
#  Social Network validation
#################################################################

:SocialNetworkShape
    a sh:NodeShape ;
    sh:targetClass cco:ont00001183 ;  # Social Network
    sh:message "Social Network validation: sub-groups must be Social Networks; members must be Persons."@en ;

    # Sub-groups: BFO has part → Social Network (e.g. Family, Colleague, Other)
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000051> ;  # has part
        sh:class cco:ont00001183 ;  # Social Network
        sh:message "Social Network parts (sub-groups) must themselves be Social Networks."@en
    ] ;

    # Members: BFO has member part → Person (used on sub-groups)
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000115> ;  # has member part
        sh:class <https://purl.org/cco/ont00001262> ;  # Person
        sh:message "All Social Network member parts must be Persons."@en
    ] .
